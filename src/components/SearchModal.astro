---
---

<div id="search-modal" class="search-modal-overlay" role="dialog" aria-modal="true" aria-label="Search" hidden>
  <div class="search-modal-backdrop"></div>
  <div class="search-modal-container">
    <div class="search-modal-box">
      <div class="search-modal-input-wrap">
        <svg class="search-modal-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="search-modal-input"
          type="text"
          class="search-modal-input"
          placeholder="Search all chapters..."
          autocomplete="off"
          aria-label="Search all chapters"
        />
        <kbd class="search-modal-esc">Esc</kbd>
      </div>
      <div id="search-modal-results" class="search-modal-results">
        <div class="search-modal-empty">Type to search across all chapters</div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-modal-input');
  const resultsContainer = document.getElementById('search-modal-results');
  if (!modal || !input || !resultsContainer) return;

  let pagefindApi = null;
  let activeIndex = -1;
  let debounceTimer = null;

  async function loadPagefind() {
    if (pagefindApi) return pagefindApi;
    try {
      pagefindApi = await import('/pagefind/pagefind.js');
      await pagefindApi.init();
      return pagefindApi;
    } catch (e) {
      return null;
    }
  }

  function open() {
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      modal.classList.add('is-open');
      input.focus();
    });
    loadPagefind();
  }

  function close() {
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    setTimeout(() => {
      modal.hidden = true;
      input.value = '';
      resultsContainer.innerHTML = '<div class="search-modal-empty">Type to search across all chapters</div>';
      activeIndex = -1;
    }, 150);
  }

  function setActive(index) {
    const items = resultsContainer.querySelectorAll('.search-modal-result');
    items.forEach(el => el.classList.remove('is-active'));
    if (index >= 0 && index < items.length) {
      activeIndex = index;
      items[index].classList.add('is-active');
      items[index].scrollIntoView({ block: 'nearest' });
      input.setAttribute('aria-activedescendant', items[index].id);
    } else {
      activeIndex = -1;
      input.removeAttribute('aria-activedescendant');
    }
  }

  async function doSearch(query) {
    const pf = await loadPagefind();
    if (!pf) {
      resultsContainer.innerHTML = '<div class="search-modal-empty">Search not available (run pnpm build first)</div>';
      return;
    }

    if (!query.trim()) {
      resultsContainer.innerHTML = '<div class="search-modal-empty">Type to search across all chapters</div>';
      activeIndex = -1;
      return;
    }

    const search = await pf.search(query);

    if (search.results.length === 0) {
      resultsContainer.innerHTML = '<div class="search-modal-empty">No results found</div>';
      activeIndex = -1;
      return;
    }

    const topResults = search.results.slice(0, 8);
    const loaded = await Promise.all(topResults.map(r => r.data()));

    let html = '';
    loaded.forEach((result, i) => {
      const title = result.meta?.title || result.url;
      html += `
        <a id="search-result-${i}" href="${result.url}" class="search-modal-result" role="option">
          <div class="search-modal-result-title">${title}</div>
          <div class="search-modal-result-excerpt">${result.excerpt}</div>
        </a>
      `;
    });

    resultsContainer.innerHTML = html;
    activeIndex = -1;
  }

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => doSearch(input.value), 150);
  });

  input.addEventListener('keydown', (e) => {
    const items = resultsContainer.querySelectorAll('.search-modal-result');
    const count = items.length;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(activeIndex < count - 1 ? activeIndex + 1 : 0);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(activeIndex > 0 ? activeIndex - 1 : count - 1);
    } else if (e.key === 'Enter' && activeIndex >= 0 && items[activeIndex]) {
      e.preventDefault();
      items[activeIndex].click();
    } else if (e.key === 'Escape') {
      e.preventDefault();
      close();
    }
  });

  modal.querySelector('.search-modal-backdrop').addEventListener('click', close);

  document.addEventListener('open-search-modal', open);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal.hidden) open(); else close();
    }
  });
})();
</script>

<style is:global>
  .search-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
    opacity: 0;
    transition: opacity 150ms ease;
  }

  .search-modal-overlay.is-open {
    opacity: 1;
  }

  .search-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .search-modal-container {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 16px;
  }

  .search-modal-box {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 25px 60px -12px rgba(0, 0, 0, 0.3);
    overflow: hidden;
  }

  .search-modal-input-wrap {
    display: flex;
    align-items: center;
    padding: 0 20px;
    border-bottom: 1px solid #e2e8f0;
  }

  .search-modal-icon {
    width: 20px;
    height: 20px;
    color: #94a3b8;
    flex-shrink: 0;
  }

  .search-modal-input {
    flex: 1;
    height: 56px;
    padding: 0 12px;
    border: none;
    outline: none;
    font-size: 16px;
    font-family: 'Inter', system-ui, sans-serif;
    color: #0f172a;
    background: transparent;
  }

  .search-modal-input::placeholder {
    color: #94a3b8;
  }

  .search-modal-esc {
    flex-shrink: 0;
    padding: 2px 8px;
    font-size: 11px;
    font-family: 'Inter', system-ui, sans-serif;
    color: #94a3b8;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
  }

  .search-modal-results {
    max-height: 60vh;
    overflow-y: auto;
    padding: 8px;
  }

  .search-modal-empty {
    padding: 32px 16px;
    text-align: center;
    font-size: 14px;
    color: #94a3b8;
  }

  .search-modal-result {
    display: block;
    padding: 12px 16px;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 80ms ease;
    cursor: pointer;
  }

  .search-modal-result:hover,
  .search-modal-result.is-active {
    background: #f1f5f9;
  }

  .search-modal-result-title {
    font-size: 14px;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 4px;
  }

  .search-modal-result.is-active .search-modal-result-title {
    color: #d14124;
  }

  .search-modal-result-excerpt {
    font-size: 13px;
    line-height: 1.5;
    color: #64748b;
  }

  .search-modal-result-excerpt mark {
    background: #fef08a;
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }
</style>
