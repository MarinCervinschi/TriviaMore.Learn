---
import CourseCard from '../components/CourseCard.astro';
import SearchBar from '../components/SearchBar.astro';
import { getAllCourseMetas } from '../utils/courses';
import '../styles/global.css';

const courses = getAllCourseMetas();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TriviaMore Learn</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:image" content="/og-default.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Inter', system-ui, sans-serif; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-40 bg-white/80 backdrop-blur-sm border-b border-slate-200">
      <div class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="text-sm font-bold gradient-text">TriviaMore Learn</a>
        <div class="hidden md:block w-64">
          <SearchBar />
        </div>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold text-slate-900">Courses</h1>
      <p class="mt-3 text-lg text-slate-600">University study materials, organized and searchable.</p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {courses.map((course) => (
          <CourseCard
            title={course.title}
            slug={course.slug}
            description={course.description}
            chapters={course.chapters}
          />
        ))}
      </div>
    </main>
  </body>
</html>
